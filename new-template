function hCell(text, width, shade = HEADER_BG) {
  return new TableCell({
    borders,
    width: { size: width, type: WidthType.DXA },
    shading: { fill: shade, type: ShadingType.CLEAR },
    margins: { top: 80, bottom: 80, left: 160, right: 120 },
    verticalAlign: VerticalAlign.CENTER,
    children: [new Paragraph({
      children: [new TextRun({ text, bold: true, color: WHITE, size: 20, font: "Arial" })]
    })]
  });
}

function labelCell(text, width, shade = LIGHT_BLUE) {
  return new TableCell({
    borders,
    width: { size: width, type: WidthType.DXA },
    shading: { fill: shade, type: ShadingType.CLEAR },
    margins: { top: 80, bottom: 80, left: 160, right: 120 },
    verticalAlign: VerticalAlign.CENTER,
    children: [new Paragraph({
      children: [new TextRun({ text, bold: true, size: 20, font: "Arial", color: "1F3864" })]
    })]
  });
}

function valueCell(children, width, shade = WHITE) {
  return new TableCell({
    borders,
    width: { size: width, type: WidthType.DXA },
    shading: { fill: shade, type: ShadingType.CLEAR },
    margins: { top: 80, bottom: 80, left: 160, right: 120 },
    children: Array.isArray(children) ? children : [new Paragraph({
      children: [new TextRun({ text: children, size: 20, font: "Arial" })]
    })]
  });
}

function textP(text, opts = {}) {
  return new Paragraph({
    children: [new TextRun({ text, size: 20, font: "Arial", ...opts })]
  });
}

function bulletP(text) {
  return new Paragraph({
    numbering: { reference: "bullets", level: 0 },
    children: [new TextRun({ text, size: 20, font: "Arial" })]
  });
}

function sectionHeaderRow(title, totalWidth) {
  return new TableRow({
    children: [new TableCell({
      borders,
      columnSpan: 2,
      width: { size: totalWidth, type: WidthType.DXA },
      shading: { fill: MID_BLUE, type: ShadingType.CLEAR },
      margins: { top: 100, bottom: 100, left: 160, right: 120 },
      children: [new Paragraph({
        children: [new TextRun({ text: title, bold: true, color: WHITE, size: 22, font: "Arial" })]
      })]
    })]
  });
}

function row2(label, valueParagraphs, shade = WHITE) {
  return new TableRow({
    children: [
      labelCell(label, 2800),
      valueCell(valueParagraphs, 6560, shade)
    ]
  });
}

function vp(text) {
  return new Paragraph({ children: [new TextRun({ text, size: 20, font: "Arial" })] });
}

function vbp(text) {
  return new Paragraph({
    numbering: { reference: "bullets", level: 0 },
    children: [new TextRun({ text, size: 20, font: "Arial" })]
  });
}

// Recommendation cell (green)
